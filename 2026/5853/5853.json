            {
                "category": "summary",
                "text": "NVIDIA has released a software update for NVIDIA\u00ae Triton Inference Server.&nbsp;<div>To protect your system, clone or update this software to Triton Server r26.05 or later from the NVIDIA <a href=\"https://github.com/triton-inference-server/server\">Triton Inference Server</a> GitHub repo.</div>",
                "title": "Summary"
            },
            {
                "category": "details",
                "text": "NVIDIA has released a software update for NVIDIA\u00ae Triton Inference Server.&nbsp;<div>To protect your system, clone or update this software to Triton Server r26.05 or later from the NVIDIA <a href=\"https://github.com/triton-inference-server/server\">Triton Inference Server</a> GitHub repo.</div>",
                "title": "Security Update Notes"
