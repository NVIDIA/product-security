        "notes": [
            {
                "category": "summary",
                "text": "NVIDIA has released a software update for NVIDIA\u00ae Megatron LM.<br><div>To protect your system, clone or update this software to version 0.15.3 or later from NVIDIA/Megatron-LM <a href=\"https://github.com/NVIDIA/Megatron-LM/releases\">on GitHub</a>.</div>",
                "title": "Summary"
            },
