            "cwe": {
                "id": "CWE-639",
                "name": "Authorization Bypass Through User-Controlled Key"
            },
            "notes": [
                {
                    "category": "summary",
                    "text": "NVIDIA NVFlare Dashboard contains a vulnerability in the user management and authentication system where an unauthenticated attacker may cause authorization bypass through user-controlled key. A successful exploit of this vulnerability may lead to privilege escalation, data tampering, information disclosure, code execution, and denial of service.",
                    "title": "Vulnerability description"
                },
                {
                    "category": "details",
                    "text": "Escalation of privilege, data tampering, information disclosure, code execution, denial of service",
                    "title": "Impacts"
