        "notes": [
            {
                "category": "summary",
                "text": "NVIDIA has released a software update for NVIDIA FLARE SDK.<div>To protect your system, clone or update this software to NVIDIA FLARE SDK v2.7.2 or later from the <a href=\"https://github.com/NVIDIA/NVFlare\">NVIDIA/NVFlare</a> GitHub repo.</div>",
                "title": "Summary"
            },
            {
