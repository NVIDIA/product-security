            "cve": "CVE-2026-24148",
            "cwe": {
                "id": "CWE-1188",
                "name": "Initialization of a Resource with an Insecure Default"
            },
            "notes": [
                {
                    "category": "summary",
                    "text": "NVIDIA Jetson for JetPack contains a vulnerability in the system initialization logic, where an unprivileged attacker could cause the initialization of a resource with an insecure default. A successful exploit of this vulnerability might lead to information disclosure of encrypted data, data tampering, and partial denial of service across devices sharing the same machine ID.",
                    "title": "Vulnerability description"
                },
                {
                    "category": "details",
                    "text": "Data tampering, information disclosure, denial of service",
                    "title": "Impacts"
                },
                {
                    "category": "details",
                    "text": "5725338",
                    "title": "defect"
                }
            ],
            "product_status": {
